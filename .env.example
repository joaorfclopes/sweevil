# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URL=mongodb://localhost/sweevil

# JWT Authentication (REQUIRED)
# Generate a secure random string for production
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AWS S3 Configuration (for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# PayPal Configuration
PAYPAL_CLIENT_ID=your-paypal-client-id

# Email Configuration (Nodemailer with Gmail OAuth2)
MAILING_SERVICE_CLIENT_ID=your-gmail-oauth-client-id
MAILING_SERVICE_CLIENT_SECRET=your-gmail-oauth-client-secret
MAILING_SERVICE_REFRESH_TOKEN=your-gmail-oauth-refresh-token
MAILING_SERVICE_ACCESS_TOKEN=your-gmail-oauth-access-token
REACT_APP_SENDER_EMAIL_ADDRESS=your-email@gmail.com

# Brand Configuration (for emails and frontend)
BRAND_NAME=Sweevil
BRAND_LOGO=https://your-logo-url.com/logo.png
REACT_APP_HOME_PAGE=http://localhost:3000
