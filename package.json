{
  "name": "sweevil",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "backend": "nodemon --watch backend --exec \"node --import ./backend/instrument.js backend/server.js\"",
    "backend:debug": "nodemon --inspect --import ./backend/instrument.js backend/server.js",
    "frontend": "node scripts/start-frontend.mjs",
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "start:debug": "concurrently \"npm run backend:debug\" \"npm run frontend\"",
    "build": "cd frontend && npm install && npm run build",
    "dos2unix": "find . -type f -name \"*.scss\" -exec dos2unix '{}' +",
    "sentry:release": "VERSION=$(git rev-parse HEAD) && export $(grep -v '^#' .env | xargs) && npx @sentry/cli releases new $VERSION --org $SENTRY_ORG && npx @sentry/cli releases set-commits $VERSION --auto --org $SENTRY_ORG && npx @sentry/cli releases finalize $VERSION --org $SENTRY_ORG",
    "deploy": "npm run build && git push heroku master --force && npm run sentry:release",
    "prepare": "husky",
    "docker": "docker compose up --build",
    "docker:debug": "docker compose -f docker-compose.yml -f docker-compose.debug.yml up --build",
    "export-prod": "node scripts/export-prod.js",
    "seed": "node scripts/seed.js --force",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit --detectOpenHandles"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaorfclopes/sweevil.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/joaorfclopes/sweevil/issues"
  },
  "homepage": "https://github.com/joaorfclopes/sweevil#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/lib-storage": "^3.1075.0",
    "@better-auth/passkey": "^1.6.19",
    "@sentry/node": "^10.53.1",
    "@sentry/profiling-node": "^10.60.0",
    "@simplewebauthn/server": "^13.3.0",
    "better-auth": "^1.6.19",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.5.2",
    "geoip-lite": "^2.0.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "mongoose": "^9.7.2",
    "multer": "^2.2.0",
    "nanoid": "^5.1.15",
    "nodemailer": "^9.0.1",
    "sharp": "^0.35.1",
    "stripe": "^22.2.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react": "^7.37.4",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^17.0.7",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "supertest": "^7.0.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "prettier --write",
    "*.{css,scss,json,md}": "prettier --write"
  }
}
