# Server Configuration
BACKEND_PORT=5000
FRONTEND_PORT=3000
NODE_ENV=development
# Canonical production domain (used for HTTPS redirect to prevent open redirect)
APP_DOMAIN=yourdomain.com

# Database
MONGODB_URL=mongodb://localhost/sweevil

# Auth (REQUIRED) — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-chars
# Backend base URL used by better-auth (must match where the backend is reachable)
BETTER_AUTH_URL=http://localhost:5000
# Frontend URL — used for passkey WebAuthn origin and trusted origins
FRONTEND_URL=http://localhost:3000

# Email allowlist — comma-separated, only these emails can sign up or sign in with Google
ALLOWED_EMAILS=email1@example.com,email2@example.com

# Google OAuth (for admin Google sign-in)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AWS S3 Configuration (for file uploads)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Configuration (Nodemailer with Gmail OAuth2)
MAILING_SERVICE_CLIENT_ID=your-gmail-oauth-client-id
MAILING_SERVICE_CLIENT_SECRET=your-gmail-oauth-client-secret
MAILING_SERVICE_REFRESH_TOKEN=your-gmail-oauth-refresh-token
MAILING_SERVICE_ACCESS_TOKEN=your-gmail-oauth-access-token
VITE_SENDER_EMAIL_ADDRESS=your-email@gmail.com

# Brand Configuration (for emails and frontend)
BRAND_NAME=Sweevil
BRAND_LOGO=https://your-logo-url.com/logo.png
VITE_HOME_PAGE=http://localhost:3000

# Geo / localisation
GEO_DEFAULT_COUNTRY=PT

# Feature flags
ENABLE_BOOKING=false
MAINTENANCE_MODE=false

# Image processing
AVIF_QUALITY=65
AVIF_EFFORT=4
IMAGE_MAX_SIZE=1000

# Sentry — error monitoring
# Get DSN from: Sentry dashboard → Settings → Projects → sweevil → Client Keys
SENTRY_DSN=
VITE_SENTRY_DSN=

# Sentry source map upload (build-time only — do not set in Heroku config vars)
# Generate at: Sentry dashboard → Settings → Auth Tokens (needs project:releases + sourcemaps:write)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Redis — API response caching
# Local: redis://localhost:6379
# Production (Upstash): rediss://default:<token>@<host>:<port>
REDIS_URL=redis://localhost:6379

MOCK_S3=true
